APP_NAME=SuperAgent RAG
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
COMPOSIO_API_KEY=
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION=superagent_memory
MAX_UPLOAD_BYTES=2000000
MAX_UPLOAD_CHUNKS=80
ALLOWED_UPLOAD_EXTENSIONS=.txt,.md,.markdown,.csv,.json,.log,.py,.js,.ts,.tsx,.html,.css,.pdf,.docx
